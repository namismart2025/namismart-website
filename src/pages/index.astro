<script>
  // Clock
  const clockEl = document.getElementById('clock');
  function tick() {
    if (!clockEl) return;
    const d = new Date();
    const p = (n: number) => String(n).padStart(2, '0');
    clockEl.textContent = `${p(d.getHours())}:${p(d.getMinutes())}:${p(d.getSeconds())}`;
  }
  tick();
  setInterval(tick, 1000);

  // Counting stats animation (triggers when panel scrolls into view)
  const nums = document.querySelectorAll<HTMLElement>('.stat-num[data-target]');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      const el = entry.target as HTMLElement;
      const target = parseInt(el.dataset.target ?? '0', 10);
      const suffix = el.dataset.suffix ?? '';
      const dur = 1700;
      const start = performance.now();
      const unit = el.querySelector('.stat-unit');
      const step = (now: number) => {
        const t = Math.min(1, (now - start) / dur);
        const e = 1 - Math.pow(1 - t, 3);
        const val = Math.round(target * e);
        if (unit) {
          el.childNodes[0].textContent = val + (suffix.includes('+') ? '+' : '');
        } else {
          el.textContent = val + suffix;
        }
        if (t < 1) requestAnimationFrame(step);
      };
      requestAnimationFrame(step);
      observer.unobserve(el);
    });
  }, { threshold: 0.4 });
  nums.forEach(n => observer.observe(n));

  // Carousel scroll dots
  const capsGrid = document.getElementById('caps-grid') as HTMLElement | null;
  const capsDots = document.querySelectorAll<HTMLElement>('.caps-dot');
  if (capsGrid && capsDots.length) {
    const updateDots = () => {
      const cards = capsGrid.querySelectorAll<HTMLElement>('.cap-card');
      if (!cards.length) return;
      const cardW = cards[0].offsetWidth + 14; // width + gap
      const idx = Math.min(Math.round(capsGrid.scrollLeft / cardW), cards.length - 1);
      capsDots.forEach((d, i) => d.classList.toggle('active', i === idx));
    };
    capsGrid.addEventListener('scroll', updateDots, { passive: true });
  }
</script>

