---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Industries Served — Security Cameras & Networking Los Angeles" description="Security camera and networking systems built for hotels, schools, apartments, commercial, retail, and luxury homes across Greater LA." breadcrumbs={[{name:'Home',url:'/'},{name:'Industries',url:'/industries'}]}>

<style>
  .sec{position:relative;z-index:4;padding:30px 56px 20px;}
  .eyebrow{font-family:'Space Mono',monospace;font-size:12px;letter-spacing:0.24em;color:#4DA6FF;margin-bottom:14px;}
  .crumb{font-family:'Space Mono',monospace;font-size:11px;letter-spacing:0.12em;color:#5E6C86;margin-bottom:18px;}
  .crumb a{color:#5E6C86;}
  .hero-panel{border:1px solid rgba(255,255,255,0.1);border-radius:20px;background:linear-gradient(160deg,#0D1220,#0A0E17);padding:46px 48px;}
  .hero-panel h1{font-family:'Archivo',sans-serif;font-weight:900;font-size:50px;line-height:0.98;letter-spacing:-0.03em;color:#fff;max-width:820px;margin:0;}
  .hero-panel h1 .blue{color:#4DA6FF;}
  .hero-panel p{font-size:16px;line-height:1.65;color:#98A4BA;margin:22px 0 0;max-width:680px;}
  .grid3{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;}
  .ind-card{border:1px solid rgba(255,255,255,0.1);border-radius:16px;background:#0E131D;overflow:hidden;}
  .ind-img{height:200px;overflow:hidden;}
  .ind-img img{width:100%;height:100%;object-fit:cover;display:block;}
  .ind-body{padding:24px;}
  .ind-body h3{font-family:'Archivo',sans-serif;font-weight:700;font-size:19px;color:#fff;margin:0;}
  .ind-body p{font-size:13.5px;line-height:1.6;color:#8B98AE;margin:8px 0 0;}
  .callout{border:1px solid rgba(77,166,255,0.22);border-radius:16px;background:linear-gradient(160deg,#0D1220,#0A0E17);padding:30px 34px;display:flex;align-items:center;justify-content:space-between;gap:28px;}
  .callout h3{font-family:'Archivo',sans-serif;font-weight:800;font-size:21px;color:#fff;margin:0;}
  .callout p{font-size:14.5px;line-height:1.6;color:#98A4BA;margin:8px 0 0;max-width:660px;}
  .callout a{white-space:nowrap;font-family:'Archivo',sans-serif;font-weight:700;font-size:14px;color:#4DA6FF;}
  @media(max-width:860px){
    .sec{padding:20px 16px;}
    .grid3{grid-template-columns:1fr;}
    .hero-panel h1{font-size:40px;}
    .callout{flex-direction:column;align-items:flex-start;}
  }
</style>

<section class="sec">
  <div class="crumb"><a href="/">HOME</a> / <span style="color:#9AA6BC">INDUSTRIES</span></div>
  <div class="hero-panel">
    <div class="eyebrow">// INDUSTRIES WE SERVE</div>
    <h1>Systems built around how your property <span class="blue">actually works.</span></h1>
    <p>From luxury homes to multi-floor hotels, we tailor camera and network design to the real needs, traffic, and risks of each type of property.</p>
  </div>
</section>

<section class="sec" style="padding-top:20px">
  <div class="grid3">
    <div class="ind-card">
      <div class="ind-img"><img src="/images/10-hotel-camera-network-system.png" alt="Hotel lobby and hallway with ceiling-mounted dome cameras" width="1672" height="941" /></div>
      <div class="ind-body"><h3>Hotels</h3><p>Multi-floor camera coverage, per-floor networking, lobby &amp; parking monitoring, guest Wi-Fi, and long-term support.</p></div>
    </div>
    <div class="ind-card">
      <div class="ind-img"><img src="/images/11-school-security-coverage.png" alt="School corridor with ceiling-mounted dome cameras and lockers" width="1672" height="941" /></div>
      <div class="ind-body"><h3>Schools</h3><p>Hallways, entries, and exterior coverage with office viewing, dependable recording, and reliable networks.</p></div>
    </div>
    <div class="ind-card">
      <div class="ind-img"><img src="/images/12-apartment-entry-parking-cameras.png" alt="Apartment complex entry and gated parking with dome and bullet cameras" width="1672" height="941" /></div>
      <div class="ind-body"><h3>Apartments &amp; Condos</h3><p>Entries, parking, mailrooms, hallways, gates, and common areas — coverage residents and managers can rely on.</p></div>
    </div>
    <div class="ind-card">
      <div class="ind-img"><img src="/images/commercial-building-exterior.png" alt="Modern commercial office building exterior with bullet and dome cameras" width="1536" height="1024" /></div>
      <div class="ind-body"><h3>Commercial &amp; Offices</h3><p>Interior &amp; perimeter cameras, business Wi-Fi, access points, and clean, organized network closets.</p></div>
    </div>
    <div class="ind-card">
      <div class="ind-img"><img src="/images/retail-floor-and-registers.png" alt="Retail store floor with checkout registers and ceiling dome cameras" width="1536" height="1024" /></div>
      <div class="ind-body"><h3>Retail &amp; Warehouses</h3><p>Register &amp; entrance coverage, aisles, storage and loading areas, plus reliable business Wi-Fi.</p></div>
    </div>
    <div class="ind-card">
      <div class="ind-img"><img src="/images/luxury-home-and-gate.png" alt="Luxury home entrance with gated driveway and dome and bullet cameras" width="1536" height="1024" /></div>
      <div class="ind-body"><h3>Large &amp; Luxury Homes</h3><p>Exterior &amp; gate coverage, remote viewing, and a home network that actually holds up under load.</p></div>
    </div>
  </div>
</section>

<section class="sec" style="padding-bottom:10px">
  <div class="callout">
    <div>
      <h3>Also serving property managers &amp; multi-site businesses</h3>
      <p>We work with medical offices, restaurants, property management companies, and multi-location operators who need consistent, well-documented systems across every site.</p>
    </div>
    <a href="/projects">See Project Types →</a>
  </div>
</section>

<section class="cta-band">
  <div>
    <div class="eyebrow" style="color:rgba(255,255,255,0.8)">// BUILT FOR YOUR PROPERTY</div>
    <h2>Let's design yours.</h2>
    <p>Camera &amp; network systems across Greater LA.</p>
  </div>
  <a href="/contact" class="btn-dark">Get a quote</a>
</section>

</Layout>
