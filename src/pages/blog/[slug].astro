---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog').catch(() => []);
  return posts.map(post => ({
    params: { slug: post.id.replace(/\.md$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={post.data.title} description={post.data.description} articleMeta={{ pubDate: post.data.pubDate, author: post.data.author, image: post.data.image }} breadcrumbs={[{name:'Home',url:'/'},{name:'Blog',url:'/blog'},{name:post.data.title,url:`/blog/${Astro.params.slug}`}]}>

{post.data.faq && post.data.faq.length > 0 && (
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": post.data.faq.map(item => ({
      "@type": "Question",
      "name": item.q,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": item.a
      }
    }))
  })} />
)}

<style>
  .sec { position:relative;z-index:4;padding:30px 56px 80px; }
  .crumb { font-family:'Space Mono',monospace;font-size:11px;letter-spacing:0.12em;color:#5E6C86;margin-bottom:18px; }
  .crumb a { color:#5E6C86; }

  .post-header {
    border:1px solid rgba(255,255,255,0.1);border-radius:20px;
    background:linear-gradient(160deg,#0D1220,#0A0E17);
    padding:46px 48px;margin-bottom:40px;
  }
  .post-tags { display:flex;flex-wrap:wrap;gap:8px;margin-bottom:18px; }
  .post-tag {
    font-family:'Space Mono',monospace;font-size:10px;letter-spacing:0.08em;
    padding:5px 12px;border-radius:999px;
    border:1px solid rgba(77,166,255,0.3);color:#4DA6FF;
  }
  .post-title {
    font-family:'Archivo',sans-serif;font-weight:900;font-size:46px;
    line-height:1.05;letter-spacing:-0.03em;color:#fff;margin:0 0 20px;
    max-width:760px;
  }
  .post-meta { display:flex;align-items:center;gap:24px; }
  .post-author { font-family:'Space Mono',monospace;font-size:12px;color:#4DA6FF;letter-spacing:0.06em; }
  .post-date { font-family:'Space Mono',monospace;font-size:12px;color:#5E6C86; }

  .post-img {
    width:100%;max-height:460px;object-fit:cover;
    border-radius:16px;margin-bottom:40px;
    border:1px solid rgba(255,255,255,0.1);
  }

  .post-body { max-width:740px; }
  .post-body :global(h2) {
    font-family:'Archivo',sans-serif;font-weight:800;font-size:28px;
    letter-spacing:-0.02em;color:#fff;margin:48px 0 16px;line-height:1.15;
  }
  .post-body :global(h3) {
    font-family:'Archivo',sans-serif;font-weight:700;font-size:20px;
    letter-spacing:-0.01em;color:#fff;margin:32px 0 12px;
  }
  .post-body :global(p) { font-size:16px;line-height:1.75;color:#98A4BA;margin:0 0 20px; }
  .post-body :global(ul), .post-body :global(ol) { padding-left:22px;margin:0 0 20px; }
  .post-body :global(li) { font-size:15.5px;line-height:1.7;color:#98A4BA;margin-bottom:8px; }
  .post-body :global(strong) { color:#fff; }
  .post-body :global(a) { color:#4DA6FF;text-decoration:underline; }
  .post-body :global(blockquote) {
    border-left:3px solid #4DA6FF;padding-left:20px;margin:28px 0;
    font-style:italic;color:#7C89A0;
  }
  .post-body :global(code) {
    font-family:'Space Mono',monospace;font-size:13px;
    background:rgba(77,166,255,0.1);color:#4DA6FF;
    padding:2px 7px;border-radius:4px;
  }
  .post-body :global(hr) { border:none;border-top:1px solid rgba(255,255,255,0.1);margin:40px 0; }

  .back-link {
    display:inline-flex;align-items:center;gap:8px;
    font-family:'Space Mono',monospace;font-size:12px;letter-spacing:0.06em;
    color:#5E6C86;margin-top:56px;text-decoration:none;transition:color 0.2s;
  }
  .back-link:hover { color:#4DA6FF; }

  @media(max-width:860px) {
    .sec { padding:20px 16px 60px; }
    .post-header { padding:28px 20px; }
    .post-title { font-size:32px; }
  }
</style>

<section class="sec">
  <div class="crumb"><a href="/">HOME</a> / <a href="/blog">BLOG</a> / <span style="color:#9AA6BC">{post.data.title.toUpperCase()}</span></div>

  <div class="post-header">
    {post.data.tags.length > 0 && (
      <div class="post-tags">
        {post.data.tags.map(tag => <span class="post-tag">{tag}</span>)}
      </div>
    )}
    <h1 class="post-title">{post.data.title}</h1>
    <div class="post-meta">
      <span class="post-author">BY {post.data.author.toUpperCase()}</span>
      <span class="post-date">{post.data.pubDate.toLocaleDateString('en-US', { month:'long', day:'numeric', year:'numeric' })}</span>
    </div>
  </div>

  {post.data.image && (
    <img src={post.data.image} alt={post.data.imageAlt || post.data.title} class="post-img" width={post.data.imageWidth || 1280} height={post.data.imageHeight || 720} />
  )}

  <div class="post-body">
    <Content />
  </div>

  <a href="/blog" class="back-link">← BACK TO BLOG</a>
</section>

</Layout>
