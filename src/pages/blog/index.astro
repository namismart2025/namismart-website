---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const toSlug = (id: string) => id.replace(/\.md$/, '');

const allPosts = await getCollection('blog').catch(() => []);
const posts = allPosts
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title="Security Camera & Networking Tips — Blog" description="Security camera and networking tips, guides, and insights for homes and businesses across Greater Los Angeles — by NaMiSmart." breadcrumbs={[{name:'Home',url:'/'},{name:'Blog',url:'/blog'}]}>

<style>
  .sec { position:relative;z-index:4;padding:30px 56px 60px; }
  .crumb { font-family:'Space Mono',monospace;font-size:11px;letter-spacing:0.12em;color:#5E6C86;margin-bottom:18px; }
  .crumb a { color:#5E6C86; }
  .eyebrow { font-family:'Space Mono',monospace;font-size:12px;letter-spacing:0.26em;color:#4DA6FF;margin-bottom:18px; }
  .heading { font-family:'Archivo',sans-serif;font-weight:900;font-size:48px;line-height:1;letter-spacing:-0.03em;color:#fff;margin:0 0 14px; }
  .subheading { font-size:16px;line-height:1.6;color:#98A4BA;max-width:560px;margin:0 0 48px; }

  .grid { display:grid;grid-template-columns:repeat(3,1fr);gap:24px; }

  .card {
    border:1px solid rgba(255,255,255,0.1);border-radius:16px;
    background:#0E131D;overflow:hidden;
    display:flex;flex-direction:column;
    transition:border-color 0.2s;
  }
  .card:hover { border-color:rgba(77,166,255,0.35); }
  .card-img { width:100%;height:200px;object-fit:cover;display:block; }
  .card-img-placeholder {
    width:100%;height:200px;
    background:linear-gradient(160deg,#0D1A2E,#0A0E17);
    display:flex;align-items:center;justify-content:center;
  }
  .card-img-placeholder svg { opacity:0.15; }
  .card-body { padding:24px;flex:1;display:flex;flex-direction:column; }
  .card-tags { display:flex;flex-wrap:wrap;gap:6px;margin-bottom:14px; }
  .card-tag {
    font-family:'Space Mono',monospace;font-size:10px;letter-spacing:0.08em;
    padding:4px 10px;border-radius:999px;
    border:1px solid rgba(77,166,255,0.3);color:#4DA6FF;
  }
  .card-title { font-family:'Archivo',sans-serif;font-weight:800;font-size:20px;line-height:1.2;letter-spacing:-0.02em;color:#fff;margin:0 0 10px; }
  .card-desc { font-size:14px;line-height:1.6;color:#8B98AE;flex:1; }
  .card-meta { display:flex;align-items:center;justify-content:space-between;margin-top:20px;padding-top:16px;border-top:1px solid rgba(255,255,255,0.07); }
  .card-date { font-family:'Space Mono',monospace;font-size:11px;color:#5E6C86; }
  .card-link { font-family:'Space Mono',monospace;font-size:11px;letter-spacing:0.06em;color:#4DA6FF; }

  .empty { text-align:center;padding:80px 0;color:#5E6C86;font-family:'Space Mono',monospace;font-size:13px; }

  @media(max-width:900px) {
    .sec { padding:20px 16px 48px; }
    .heading { font-size:36px; }
    .grid { grid-template-columns:1fr; }
  }
  @media(min-width:901px) and (max-width:1100px) {
    .grid { grid-template-columns:repeat(2,1fr); }
  }
</style>

<section class="sec">
  <div class="crumb"><a href="/">HOME</a> / <span style="color:#9AA6BC">BLOG</span></div>
  <div class="eyebrow">// INSIGHTS & GUIDES</div>
  <h1 class="heading">Security & Networking<br/>Knowledge Base</h1>
  <p class="subheading">Practical guides, tips, and insights for homeowners and businesses across Greater Los Angeles.</p>

  {posts.length === 0 ? (
    <div class="empty">// First post coming soon</div>
  ) : (
    <div class="grid">
      {posts.map(post => (
        <a href={`/blog/${toSlug(post.id)}`} class="card" style="text-decoration:none;">
          {post.data.image ? (
            <img src={post.data.image} alt={post.data.imageAlt || post.data.title} class="card-img" width={post.data.imageWidth || 1280} height={post.data.imageHeight || 720} />
          ) : (
            <div class="card-img-placeholder">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#4DA6FF" stroke-width="1.5">
                <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/>
                <path d="m21 15-5-5L5 21"/>
              </svg>
            </div>
          )}
          <div class="card-body">
            {post.data.tags.length > 0 && (
              <div class="card-tags">
                {post.data.tags.slice(0,3).map(tag => <span class="card-tag">{tag}</span>)}
              </div>
            )}
            <div class="card-title">{post.data.title}</div>
            <div class="card-desc">{post.data.description}</div>
            <div class="card-meta">
              <span class="card-date">{post.data.pubDate.toLocaleDateString('en-US', { month:'short', day:'numeric', year:'numeric' })}</span>
              <span class="card-link">READ MORE →</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  )}
</section>

</Layout>
