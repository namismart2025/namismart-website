---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page Not Found" description="The page you're looking for doesn't exist. Head back to NaMiSmart to find security camera and networking services across Greater Los Angeles.">

<style>
  .not-found {
    position: relative; z-index: 4;
    min-height: 72vh;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    text-align: center;
    padding: 80px 24px;
  }
  .code {
    font-family: 'Space Mono', monospace;
    font-size: 120px; font-weight: 700;
    line-height: 1; letter-spacing: -0.04em;
    color: transparent;
    -webkit-text-stroke: 1.5px rgba(77,166,255,0.35);
    margin: 0;
    user-select: none;
  }
  .eyebrow {
    font-family: 'Space Mono', monospace;
    font-size: 11px; letter-spacing: 0.24em;
    color: #4DA6FF; margin: 24px 0 18px;
  }
  .headline {
    font-family: 'Archivo', sans-serif;
    font-weight: 800; font-size: 36px;
    letter-spacing: -0.02em; color: #fff;
    margin: 0 0 14px; line-height: 1.1;
    max-width: 520px;
  }
  .sub {
    font-size: 15px; line-height: 1.7;
    color: #8B98AE; max-width: 440px; margin: 0 auto 38px;
  }
  .btns { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }
  .btn-primary {
    font-family: 'Archivo', sans-serif; font-weight: 800;
    font-size: 14.5px; padding: 14px 28px;
    background: #4DA6FF; color: #04101F;
    border-radius: 10px;
  }
  .btn-primary:hover { background: #3b96f0; transition: background 0.15s; }
  .btn-secondary {
    font-family: 'Archivo', sans-serif; font-weight: 700;
    font-size: 14.5px; padding: 14px 28px;
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 10px; color: #C4CEDE;
  }
  .btn-secondary:hover { border-color: rgba(255,255,255,0.3); color: #fff; transition: all 0.15s; }
  .links-row {
    display: flex; flex-wrap: wrap; gap: 10px;
    justify-content: center; margin-top: 52px;
  }
  .link-chip {
    font-family: 'Space Mono', monospace; font-size: 11px;
    padding: 8px 14px; border-radius: 999px;
    border: 1px solid rgba(77,166,255,0.25);
    color: #9EC5F5; letter-spacing: 0.06em;
  }
  .link-chip:hover { border-color: rgba(77,166,255,0.55); color: #4DA6FF; transition: all 0.15s; }
  .divider {
    font-family: 'Space Mono', monospace; font-size: 11px;
    color: #3a4557; margin-top: 48px; letter-spacing: 0.12em;
  }
</style>

<div class="not-found">
  <p class="code">404</p>
  <div class="eyebrow">// PAGE NOT FOUND</div>
  <h1 class="headline">This page doesn't exist — but your install can.</h1>
  <p class="sub">The URL you followed may be broken or the page may have been removed. Head back to find security cameras, networking, and cabling services across Greater Los Angeles.</p>
  <div class="btns">
    <a href="/" class="btn-primary">Back to Home</a>
    <a href="/contact" class="btn-secondary">Request an Estimate</a>
  </div>
  <div class="links-row">
    <a href="/security-cameras" class="link-chip">SECURITY CAMERAS</a>
    <a href="/networking-wifi" class="link-chip">NETWORKING & WI-FI</a>
    <a href="/structured-cabling" class="link-chip">STRUCTURED CABLING</a>
    <a href="/maintenance" class="link-chip">MAINTENANCE</a>
    <a href="/about" class="link-chip">ABOUT</a>
    <a href="/blog" class="link-chip">BLOG</a>
  </div>
  <div class="divider">// NAMISMART · GREATER LOS ANGELES</div>
</div>

</Layout>
