---
import Layout from '../layouts/Layout.astro';
import InnerHero from '../components/InnerHero.astro';
import heroImage from '../assets/images/09-nvr-camera-monitors.png';

const faqs = [
  {
    q: 'Do your outdoor cameras hold up in high-desert heat and dust?',
    a: 'Yes. Properties in Lancaster and Palmdale need outdoor-rated equipment that can handle extreme summer heat, dust, and temperature swings — that\'s the standard we install to, not general-purpose cameras rated for milder coastal climates.'
  },
  {
    q: 'Do you charge extra to travel to Lancaster or Palmdale?',
    a: 'No. A lot of LA-based installers treat the Antelope Valley as out-of-area and add travel surcharges, or decline the work outright. We serve Lancaster, Palmdale, and the surrounding Antelope Valley as part of our regular coverage area with no markup.'
  },
  {
    q: 'Can you network a large warehouse or manufacturing facility?',
    a: 'Yes — this is common work for us in the Antelope Valley. That includes wired access points across large floor plates, high-bay camera mounting, loading dock coverage, and network racks sized for heavy device loads in warehouse and manufacturing environments.'
  },
  {
    q: 'What about large rural or ranch-style properties with buildings spread far apart?',
    a: 'We design for that specifically — long-range outdoor cameras, gate and driveway coverage, and wireless bridging or solar-compatible setups when running cable between distant buildings isn\'t practical.'
  }
];
const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a }
  }))
};
---

<Layout
  title="Security Camera & Network Installation — Lancaster & Palmdale"
  description="Security camera installation and enterprise networking in Lancaster and Palmdale — serving the Antelope Valley including Quartz Hill, Rosamond, Littlerock, and surrounding communities."
  ogImage="/images/og/og-lancaster-palmdale.png"
  breadcrumbs={[{name:'Home',url:'/'},{name:'Lancaster & Palmdale',url:'/lancaster-palmdale'}]}
>

<style>
  .sec { position:relative;z-index:4;padding:30px 56px 20px; }
  .eyebrow { font-family:'Space Mono',monospace;font-size:12px;letter-spacing:0.24em;color:#4DA6FF;margin-bottom:14px; }
  .grid3 { display:grid;grid-template-columns:repeat(3,1fr);gap:16px; }
  .grid2 { display:grid;grid-template-columns:1fr 1fr;gap:20px; }
  .card { border:1px solid rgba(255,255,255,0.1);border-radius:14px;background:#0E131D;padding:22px; }
  .card h3 { font-family:'Archivo',sans-serif;font-weight:700;font-size:16.5px;color:#fff;margin:0; }
  .card p  { font-size:13.5px;line-height:1.55;color:#8B98AE;margin:8px 0 0; }
  .card a  { font-size:13px;color:#4DA6FF;margin-top:10px;display:inline-block; }
  .card-lg { border:1px solid rgba(255,255,255,0.1);border-radius:16px;background:linear-gradient(160deg,#0D1220,#0A0E17);padding:30px; }
  .card-lg h3 { font-family:'Archivo',sans-serif;font-weight:800;font-size:24px;line-height:1.12;color:#fff;margin:0; }
  .card-lg p  { font-size:14.5px;line-height:1.65;color:#98A4BA;margin:14px 0 0; }
  .tag-row { display:flex;flex-direction:column;gap:12px;justify-content:center; }
  .tri { display:flex;align-items:center;gap:14px;border:1px solid rgba(255,255,255,0.1);border-radius:14px;background:#0E131D;padding:16px 20px; }
  .tl { font-family:'Space Mono',monospace;font-size:11px;color:#4DA6FF;width:110px;letter-spacing:0.08em; }
  .tri span:last-child { font-size:13.5px;color:#B9C6DC; }
  .sys-grid { display:grid;grid-template-columns:repeat(3,1fr);gap:20px; }
  .sys-card { border:1px solid rgba(255,255,255,0.1);border-radius:16px;background:#0E131D;padding:28px; }
  .sys-card h3 { font-family:'Archivo',sans-serif;font-weight:800;font-size:21px;color:#fff;margin:0; }
  .sys-card p  { font-size:14px;line-height:1.6;color:#8B98AE;margin:10px 0 0; }
  .sys-card a  { font-size:13px;color:#4DA6FF;margin-top:12px;display:inline-block; }
  .callout { border:1px solid rgba(77,166,255,0.22);border-radius:16px;background:linear-gradient(160deg,#0D1220,#0A0E17);padding:30px 34px;display:flex;align-items:center;justify-content:space-between;gap:28px; }
  .callout h3 { font-family:'Archivo',sans-serif;font-weight:800;font-size:21px;color:#fff;margin:0; }
  .callout p  { font-size:14.5px;line-height:1.6;color:#98A4BA;margin:8px 0 0;max-width:640px; }
  .callout a  { white-space:nowrap;font-family:'Archivo',sans-serif;font-weight:700;font-size:14px;color:#4DA6FF; }
  .areas-tags { display:flex;flex-wrap:wrap;gap:9px;margin-top:16px; }
  .atag { font-family:'Space Mono',monospace;font-size:11px;padding:7px 13px;border-radius:999px;border:1px solid rgba(77,166,255,0.3);color:#9EC5F5; }
  .intro-block { max-width:760px; }
  .intro-block h2 { font-family:'Archivo',sans-serif;font-weight:800;font-size:34px;letter-spacing:-0.02em;color:#fff;margin:0 0 16px;line-height:1.1; }
  .intro-block p { font-size:15px;line-height:1.75;color:#98A4BA;margin:0; }
  .faq-item { border:1px solid rgba(255,255,255,0.1);border-radius:14px;background:#0E131D;padding:20px 22px;margin-bottom:12px; }
  .faq-item summary { font-family:'Archivo',sans-serif;font-weight:700;font-size:16px;color:#fff;cursor:pointer;list-style:none; }
  .faq-item summary::-webkit-details-marker { display:none; }
  .faq-item summary::after { content:'+';float:right;color:#4DA6FF;font-weight:400; }
  .faq-item[open] summary::after { content:'−'; }
  .faq-item p { font-size:14px;line-height:1.65;color:#98A4BA;margin:12px 0 0; }
  @media(max-width:860px){ .sec{padding:20px 16px;} .grid3,.grid2,.sys-grid{grid-template-columns:1fr;} .callout{flex-direction:column;align-items:flex-start;} }
</style>

<script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

<InnerHero
  breadcrumb="LANCASTER & PALMDALE"
  eyebrow="// LANCASTER & PALMDALE"
  title="Security cameras & networking"
  titleBlue="in the Antelope Valley."
  subtitle="Camera systems, enterprise Wi-Fi, and structured cabling for businesses, warehouses, schools, and commercial properties throughout Lancaster, Palmdale, and the surrounding Antelope Valley."
  tags={['SECURITY CAMERAS','ENTERPRISE WI-FI','STRUCTURED CABLING','ANTELOPE VALLEY']}
  ctaLabel="Request a Free Estimate →"
  ctaHref="/contact"
  secondaryLabel="See Our Work"
  secondaryHref="/projects"
  image={heroImage}
  imageAlt="NVR security camera monitoring system in Antelope Valley property"
  statusLabel="ANTELOPE VALLEY · ACTIVE COVERAGE"
  statusColor="#3BE07F"
/>

<section class="sec">
  <div class="intro-block">
    <div class="eyebrow">// SERVING THE ANTELOPE VALLEY</div>
    <h2>Large properties, wide open spaces — and the right systems to cover them.</h2>
    <p>The Antelope Valley has its own challenges. Large warehouse footprints, wide commercial parcels, aerospace and manufacturing facilities, high-desert conditions that stress outdoor equipment, and long distances between buildings. A standard setup designed for a small LA office does not hold up here. We design security camera and networking systems built for the size and environment of Antelope Valley properties — industrial-grade outdoor cameras, wired access points that cover large floor areas, and clean cabling that lasts.</p>
  </div>
</section>

<section class="sec">
  <div class="eyebrow">// COMMUNITIES WE SERVE</div>
  <h2 style="font-family:'Archivo',sans-serif;font-weight:800;font-size:28px;letter-spacing:-0.02em;color:#fff;margin:0 0 6px">Across Lancaster, Palmdale & the Antelope Valley</h2>
  <p style="font-size:14px;color:#8B98AE;margin:0">From the 14 freeway corridor to the high desert communities.</p>
  <div class="areas-tags" style="margin-top:18px">
    <span class="atag">LANCASTER</span>
    <span class="atag">PALMDALE</span>
    <span class="atag">QUARTZ HILL</span>
    <span class="atag">ROSAMOND</span>
    <span class="atag">LITTLEROCK</span>
    <span class="atag">LAKE LOS ANGELES</span>
    <span class="atag">ACTON</span>
    <span class="atag">PEARBLOSSOM</span>
    <span class="atag">TEHACHAPI</span>
  </div>
</section>

<section class="sec">
  <div class="eyebrow">// WHAT WE INSTALL</div>
  <h2 style="font-family:'Archivo',sans-serif;font-weight:800;font-size:34px;letter-spacing:-0.02em;color:#fff;margin:0 0 22px">Three systems. One install team.</h2>
  <div class="sys-grid">
    <div class="sys-card">
      <h3>Security Cameras</h3>
      <p>Outdoor-rated cameras built for high-desert conditions, wide-angle coverage for large industrial parcels, and 4K recording for warehouse floors, parking lots, and perimeter fencing.</p>
      <a href="/security-cameras">Security cameras →</a>
    </div>
    <div class="sys-card">
      <h3>Networking & Wi-Fi</h3>
      <p>Enterprise Wi-Fi designed to cover large floor plates, wired access points for warehouses and manufacturing floors, and clean network racks that support heavy device loads.</p>
      <a href="/networking-wifi">Networking & Wi-Fi →</a>
    </div>
    <div class="sys-card">
      <h3>Structured Cabling</h3>
      <p>Cat6 runs across large commercial spaces, patch panels, and labeled racks — the backbone that keeps cameras and networks reliable over time, even in demanding environments.</p>
      <a href="/structured-cabling">Structured cabling →</a>
    </div>
  </div>
</section>

<section class="sec">
  <div class="grid2">
    <div class="card-lg">
      <div class="eyebrow">// WHY IT MATTERS UP HERE</div>
      <h3>Most installers treat the Antelope Valley as out-of-area. We don't.</h3>
      <p>Lancaster and Palmdale are far enough from central LA that many installers add significant travel fees or decline the work entirely. NaMiSmart serves the Antelope Valley as part of our regular service area — with no out-of-area penalties and the same quality of installation we provide everywhere else.</p>
    </div>
    <div class="tag-row">
      <div class="tri"><span class="tl">NO MARKUP</span><span>no out-of-area fees for AV projects</span></div>
      <div class="tri"><span class="tl">ENVIRONMENT</span><span>outdoor-rated equipment for desert conditions</span></div>
      <div class="tri"><span class="tl">SCALE</span><span>experience with large industrial & warehouse layouts</span></div>
    </div>
  </div>
</section>

<section class="sec">
  <div class="eyebrow">// INDUSTRIES WE SERVE</div>
  <h2 style="font-family:'Archivo',sans-serif;font-weight:800;font-size:28px;letter-spacing:-0.02em;color:#fff;margin:0 0 22px">Every property type in the Antelope Valley</h2>
  <div class="grid3">
    <div class="card">
      <h3>Warehouses & Logistics</h3>
      <p>High-bay camera mounting, wide-angle floor coverage, loading dock monitoring, and wired networking across large warehouse footprints in Lancaster and Palmdale industrial parks.</p>
    </div>
    <div class="card">
      <h3>Manufacturing & Aerospace</h3>
      <p>Secure facility camera coverage, perimeter monitoring, and reliable networking for manufacturing and aerospace-adjacent operations throughout the Antelope Valley.</p>
    </div>
    <div class="card">
      <h3>Retail & Commercial</h3>
      <p>Register and entrance cameras, stockroom coverage, and business Wi-Fi for retail centers along Avenue K, Avenue S, and the main Lancaster and Palmdale commercial corridors.</p>
    </div>
    <div class="card">
      <h3>Schools & Districts</h3>
      <p>Campus-wide security cameras, perimeter and entry coverage, and reliable networking for schools throughout the Antelope Valley Unified and William S. Hart districts.</p>
    </div>
    <div class="card">
      <h3>Large Properties & Ranches</h3>
      <p>Long-range outdoor cameras, gate and driveway coverage, solar-compatible setups, and networking for large rural and semi-rural properties common throughout the high desert.</p>
    </div>
    <div class="card">
      <h3>Medical & Government</h3>
      <p>Patient area cameras, HIPAA-aware network segmentation, and reliable systems for medical offices and government facilities in Lancaster and Palmdale.</p>
    </div>
  </div>
</section>

<section class="sec" style="padding-bottom:10px">
  <div class="callout">
    <div>
      <h3>System not working the way it should?</h3>
      <p>We service, upgrade, and redesign existing camera and network setups across the Antelope Valley — including systems that have become unreliable or were never installed properly to begin with.</p>
    </div>
    <a href="/maintenance">Maintenance & Support →</a>
  </div>
</section>

<section class="sec">
  <div class="eyebrow">// ANTELOPE VALLEY FAQ</div>
  <h2 style="font-family:'Archivo',sans-serif;font-weight:800;font-size:28px;letter-spacing:-0.02em;color:#fff;margin:0 0 22px">Common questions from Lancaster & Palmdale property owners</h2>
  {faqs.map(f => (
    <details class="faq-item">
      <summary>{f.q}</summary>
      <p>{f.a}</p>
    </details>
  ))}
</section>

<section class="cta-band">
  <div>
    <div class="eyebrow" style="color:rgba(255,255,255,0.8)">// LANCASTER & PALMDALE</div>
    <h2>Let's design the right system for your Antelope Valley property.</h2>
    <p>Free on-site assessment & quote. No out-of-area fees.</p>
  </div>
  <a href="/contact" class="btn-dark">Request an estimate</a>
</section>

</Layout>
